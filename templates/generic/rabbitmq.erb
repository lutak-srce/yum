##
## RabbitMQ Server
##

[rabbitmq-el<%= @facts['os']['release']['major'] %>]
name=rabbitmq-el<%= @facts['os']['release']['major'] %>
<% if @baseurl -%>
baseurl=<%= @baseurl %>
<% else -%>
baseurl=https://yum2.rabbitmq.com/rabbitmq/el/<%= @facts['os']['release']['major'] %>/$basearch
        https://yum1.rabbitmq.com/rabbitmq/el/<%= @facts['os']['release']['major'] %>/$basearch
<% end -%>
repo_gpgcheck=1
enabled=1
# Cloudsmith's repository key and RabbitMQ package signing key
gpgkey=https://github.com/rabbitmq/signing-keys/releases/download/3.0/cloudsmith.rabbitmq-server.9F4587F226208342.key
       https://github.com/rabbitmq/signing-keys/releases/download/3.0/rabbitmq-release-signing-key.asc
gpgcheck=1
sslverify=1
sslcacert=/etc/pki/tls/certs/ca-bundle.crt
metadata_expire=300
pkg_gpgcheck=1
autorefresh=1
type=rpm-md
priority=<%= @priority %>
<% unless @exclude.empty? -%>
exclude=<%= @exclude.to_a.join(' ') %>
<% end -%>
<% unless @include.empty? -%>
includepkgs=<%= @include.to_a.join(' ') %>
<% end -%>

[rabbitmq-el<%= @facts['os']['release']['major'] %>-noarch]
name=rabbitmq-el<%= @facts['os']['release']['major'] %>-noarch
<% if @baseurl -%>
baseurl=<%= @baseurl.sub('$basearch', 'noarch') %>
<% else -%>
baseurl=https://yum2.rabbitmq.com/rabbitmq/el/<%= @facts['os']['release']['major'] %>/noarch
        https://yum1.rabbitmq.com/rabbitmq/el/<%= @facts['os']['release']['major'] %>/noarch
<% end -%>
repo_gpgcheck=1
enabled=1
# Cloudsmith's repository key and RabbitMQ package signing key
gpgkey=https://github.com/rabbitmq/signing-keys/releases/download/3.0/cloudsmith.rabbitmq-server.9F4587F226208342.key
       https://github.com/rabbitmq/signing-keys/releases/download/3.0/rabbitmq-release-signing-key.asc
gpgcheck=1
sslverify=1
sslcacert=/etc/pki/tls/certs/ca-bundle.crt
metadata_expire=300
pkg_gpgcheck=1
autorefresh=1
type=rpm-md
priority=<%= @priority %>
<% unless @exclude.empty? -%>
exclude=<%= @exclude.to_a.join(' ') %>
<% end -%>
<% unless @include.empty? -%>
includepkgs=<%= @include.to_a.join(' ') %>
<% end -%>
