##
## Zero dependency Erlang RPM
##

[modern-erlang]
name=modern-erlang-el<%= @facts['os']['release']['major'] %>
# Use a set of mirrors maintained by the RabbitMQ core team.
# The mirrors have significantly higher bandwidth quotas.
<% if @baseurl -%>
baseurl=<%= @baseurl %>
<% else -%>
baseurl=https://yum1.rabbitmq.com/erlang/el/<%= @facts['os']['release']['major'] %>/$basearch
        https://yum2.rabbitmq.com/erlang/el/<%= @facts['os']['release']['major'] %>/$basearch
<% end -%>
repo_gpgcheck=1
enabled=1
gpgkey=https://github.com/rabbitmq/signing-keys/releases/download/3.0/cloudsmith.rabbitmq-erlang.E495BB49CC4BBE5B.key
gpgcheck=1
sslverify=1
sslcacert=/etc/pki/tls/certs/ca-bundle.crt
metadata_expire=300
pkg_gpgcheck=1
autorefresh=1
type=rpm-md
priority=<%= @priority %>
<% unless @exclude.empty? -%>
exclude=<%= @exclude.to_a.join(' ') %>
<% end -%>
<% unless @include.empty? -%>
includepkgs=<%= @include.to_a.join(' ') %>
<% end -%>

[modern-erlang-noarch]
name=modern-erlang-el<%= @facts['os']['release']['major'] %>-noarch
# Use a set of mirrors maintained by the RabbitMQ core team.
# The mirrors have significantly higher bandwidth quotas.
<% if @baseurl -%>
baseurl=<%= @baseurl.sub('$basearch', 'noarch') %>
<% else -%>
baseurl=https://yum1.rabbitmq.com/erlang/el/<%= @facts['os']['release']['major'] %>/noarch
        https://yum2.rabbitmq.com/erlang/el/<%= @facts['os']['release']['major'] %>/noarch
<% end -%>
repo_gpgcheck=1
enabled=1
gpgkey=https://github.com/rabbitmq/signing-keys/releases/download/3.0/cloudsmith.rabbitmq-erlang.E495BB49CC4BBE5B.key
       https://github.com/rabbitmq/signing-keys/releases/download/3.0/rabbitmq-release-signing-key.asc
gpgcheck=1
sslverify=1
sslcacert=/etc/pki/tls/certs/ca-bundle.crt
metadata_expire=300
pkg_gpgcheck=1
autorefresh=1
type=rpm-md
